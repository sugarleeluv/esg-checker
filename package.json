{
  "name": "esg-checker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:check": "tsx scripts/test-db.ts",
    "dev:start": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "db:stop-prisma": "npx prisma dev stop default",
    "db:ls-prisma": "npx prisma dev ls",
    "db:start-prisma": "npx prisma dev -d",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose up -d",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "sync:sheet": "tsx scripts/sync-from-sheet.ts",
    "sync:idx": "tsx scripts/sync-idx-profiles.ts",
    "sync:all": "npm run sync:sheet && npm run sync:idx",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^17.4.2",
    "next": "16.2.7",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
